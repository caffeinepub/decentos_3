export function AppStore({ windowProps: _windowProps }: AppStoreProps) {
  const [confirmApp, setConfirmApp] = useState<ExtendedAppInfo | null>(null);
  const [selectedCategory, setSelectedCategory] = useState<Category>("All");
  const [searchQuery, setSearchQuery] = useState("");
  const [debouncedQuery, setDebouncedQuery] = useState("");
  const [recentlyInstalled, setRecentlyInstalled] = useState<ExtendedAppInfo[]>(
    [],
  );
  const debounceRef = useRef<ReturnType<typeof setTimeout> | null>(null);
  const [visibleCount, setVisibleCount] = useState(24);
  const sentinelRef = useRef<HTMLDivElement>(null);
  const { openApp } = useOS();

  // Debounce search
  useEffect(() => {
    if (debounceRef.current) clearTimeout(debounceRef.current);
    debounceRef.current = setTimeout(() => setDebouncedQuery(searchQuery), 150);
    return () => {
      if (debounceRef.current) clearTimeout(debounceRef.current);
    };
  }, [searchQuery]);

  // Reset visible count on filter changes
  // biome-ignore lint/correctness/useExhaustiveDependencies: intentional reset on filter change
  useEffect(() => {
    setVisibleCount(24);
  }, [selectedCategory, debouncedQuery]);

  // IntersectionObserver for infinite scroll
  // biome-ignore lint/correctness/useExhaustiveDependencies: re-observe when filters change
  useEffect(() => {
    const el = sentinelRef.current;
    if (!el) return;
    const obs = new IntersectionObserver(
      (entries) => {
        if (entries[0]?.isIntersecting) {
          setVisibleCount((n) => n + 12);
        }
      },
      { threshold: 0.1 },
    );
    obs.observe(el);
    return () => obs.disconnect();
  }, [selectedCategory, debouncedQuery]);

  const { installedIds, install, uninstall } = useInstalledApps();

  // Backend mutations (fire-and-forget, errors are ignored)
  const { data: availableApps, isLoading: loadingAll } = useListAvailableApps();
  const installApp = useInstallApp();
  const uninstallApp = useUninstallApp();
  const grantPermissions = useGrantPermissions();
  const revokePermissions = useRevokePermissions();

  const displayApps: ExtendedAppInfo[] =
    availableApps && availableApps.length > 0
      ? (availableApps as ExtendedAppInfo[])
      : BUILTIN_APPS;

  const filteredApps = useMemo(
    () =>
      displayApps.filter((app) => {
        const matchesCategory =
          selectedCategory === "All" || app.category === selectedCategory;
        const matchesSearch =
          !debouncedQuery ||
          app.name.toLowerCase().includes(debouncedQuery.toLowerCase()) ||
          app.description.toLowerCase().includes(debouncedQuery.toLowerCase());
        return matchesCategory && matchesSearch;
      }),
    [displayApps, selectedCategory, debouncedQuery],
  );

  const featuredApps = displayApps.filter((a) => a.featured && !a.isCore);

  const handleInstall = async (app: ExtendedAppInfo) => {
    setConfirmApp(null);
    const installedApp: InstalledApp = {
      id: app.id,
      appId: app.appId ?? "",
      name: app.name,
      emoji: app.emoji ?? "����",
      emojiColor: app.emojiColor ?? "#64748B",
    };
    install(installedApp);
    setRecentlyInstalled((prev) => {
      const next = [app, ...prev.filter((a) => a.id !== app.id)].slice(0, 3);
      return next;
    });
    toast.success(`${app.name} added to desktop`);
    // Attempt backend (ignore failures)
    try {
      await grantPermissions.mutateAsync({
        appId: app.id,
        permissions: app.permissions ?? [],
      });
      await installApp.mutateAsync(app.id);
    } catch {}
    if (app.appId) {
      openApp(app.appId, app.name);
    }
  };

  const handleUninstall = async (app: ExtendedAppInfo) => {
    uninstall(app.id);
    toast.success(`${app.name} removed from desktop`);
    // Attempt backend (ignore failures)
    try {
      await revokePermissions.mutateAsync(app.id);
      await uninstallApp.mutateAsync(app.id);
    } catch {}
  };

  const handleLaunch = (app: ExtendedAppInfo) => {
    if (app.appId) {
      openApp(app.appId, app.name);
    }
  };

  return (
    <div className="flex h-full" style={{ background: "var(--os-bg-app)" }}>
      {/* Sidebar */}
      <div
        className="w-40 flex-shrink-0 flex flex-col border-r py-3"
        style={{
          borderColor: "var(--os-border-subtle)",
          background: "var(--os-bg-app)",
        }}
      >
        <div className="px-3 mb-3">
          <p className="text-[10px] font-semibold uppercase tracking-widest text-muted-foreground/50">
            Categories
          </p>
        </div>
        {CATEGORIES.map((cat) => (
          <button
            type="button"
            key={cat}
            onClick={() => setSelectedCategory(cat)}
            data-ocid={`appstore.${cat.toLowerCase()}.tab`}
            className="flex items-center gap-2 px-3 py-1.5 text-xs transition-all text-left"
            style={
              selectedCategory === cat
                ? {
                    background: "rgba(99,102,241,0.15)",
                    borderLeft: "2px solid rgba(99,102,241,0.8)",
                    color: "rgba(165,168,255,0.95)",
                    paddingLeft: "10px",
                  }
                : {
                    color: "rgba(160,160,170,0.7)",
                    borderLeft: "2px solid transparent",
                  }
            }
          >
            <span>{CATEGORY_ICONS[cat]}</span>
            {cat}
          </button>
        ))}

        <div className="flex-1" />
        <div
          className="px-3 mt-3 pt-3 border-t"
          style={{ borderColor: "var(--os-border-subtle)" }}
        >
          <p className="text-[10px] text-muted-foreground/30 leading-relaxed">
            DecentOS Marketplace
            <br />
            <span style={{ color: "var(--os-text-muted)" }}>
              v5.0 ��� on-chain
            </span>
          </p>
        </div>
      </div>

      {/* Main content */}
      <div className="flex-1 flex flex-col min-w-0">
        {/* Header / Search */}
        <div
          className="px-4 py-3 border-b flex items-center gap-3 flex-shrink-0"
          style={{
            borderColor: "var(--os-border-subtle)",
            background: "var(--os-bg-app)",
          }}
        >
          <div className="relative flex-1">
            <Search className="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-muted-foreground/50" />
            <input
              type="text"
              placeholder="Search apps..."
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              data-ocid="appstore.search_input"
              className="w-full h-8 pl-8 pr-7 rounded-md text-xs bg-white/5 border text-foreground placeholder-muted-foreground/40 outline-none transition-colors focus:border-cyan-500/40"
              style={{ border: "1px solid var(--os-border-subtle)" }}
            />
            {searchQuery && (
              <button
                type="button"
                onClick={() => setSearchQuery("")}
                className="absolute right-2.5 top-1/2 -translate-y-1/2 text-muted-foreground/40 hover:text-muted-foreground/70 transition-colors"
              >
                <X className="w-3.5 h-3.5" />
              </button>
            )}
          </div>
          <div className="text-[10px] text-muted-foreground/40 flex-shrink-0">
            {filteredApps.length} app{filteredApps.length !== 1 ? "s" : ""}
          </div>
        </div>

        <div className="flex-1 overflow-y-auto">
          {loadingAll ? (
            <div
              className="flex items-center justify-center h-full"
              data-ocid="appstore.loading_state"
            >
              <Loader2 className="w-5 h-5 animate-spin text-primary/60" />
            </div>
          ) : (
            <div className="p-4 space-y-6">
              {/* Recently Installed strip */}
              {selectedCategory === "All" &&
                !debouncedQuery &&
                recentlyInstalled.length > 0 && (
                  <div>
                    <div className="flex items-center gap-2 mb-2">
                      <span className="text-[10px]">����</span>
                      <h3
                        className="text-xs font-semibold"
                        style={{ color: "var(--os-text-secondary)" }}
                      >
                        Recently Installed
                      </h3>
                    </div>
                    <div className="flex gap-2 flex-wrap">
                      {recentlyInstalled.map((app) => (
                        <button
                          key={app.id}
                          type="button"
                          onClick={() =>
                            app.appId && openApp(app.appId, app.name)
                          }
                          className="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs transition-all hover:opacity-80"
                          style={{
                            background: "rgba(39,215,224,0.08)",
                            border: "1px solid rgba(39,215,224,0.2)",
                            color: "rgba(39,215,224,0.85)",
                          }}
                        >
                          {app.appId && <AppIcon appId={app.appId} size={12} />}
                          {app.name}
                        </button>
                      ))}
                    </div>
                  </div>
                )}

              {/* Featured row ��� only when All & no search */}
              {selectedCategory === "All" &&
                !debouncedQuery &&
                featuredApps.length > 0 && (
                  <div>
                    <div className="flex items-center gap-2 mb-3">
                      <Star
                        className="w-3.5 h-3.5"
                        style={{ color: "rgba(39,215,224,0.7)" }}
                      />
                      <h3
                        className="text-xs font-semibold"
                        style={{ color: "rgba(39,215,224,0.8)" }}
                      >
                        Featured
                      </h3>
                    </div>
                    <div className="flex gap-3 overflow-x-auto pb-2">
                      {featuredApps.map((app, i) => {
                        const isInstalled = installedIds.has(app.id);
                        return (
                          <div
                            key={app.id}
                            data-ocid={`appstore.featured.card.${i + 1}`}
                            className="flex-shrink-0 w-52 rounded-xl p-4 flex flex-col gap-3 relative overflow-hidden"
                            style={{
                              background: "rgba(18,32,38,0.9)",
                              border: "1px solid rgba(39,215,224,0.2)",
                              boxShadow: "0 0 30px rgba(39,215,224,0.05)",
                            }}
                          >
                            <div
                              className="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
                              style={{
                                background: "rgba(39,215,224,0.08)",
                              }}
                            >
                              {app.appId ? (
                                <AppIcon appId={app.appId} size={24} />
                              ) : (
                                <AppIcon appId="unknown" size={24} />
                              )}
                            </div>
                            <div>
                              <div className="flex items-center gap-2">
                                <span className="text-sm font-semibold text-foreground">
                                  {app.name}
                                </span>
                                {isInstalled && (
                                  <span
                                    className="text-[10px] px-1.5 py-0.5 rounded-full"
                                    style={{
                                      background: "rgba(39,215,224,0.1)",
                                      color: "rgba(39,215,224,0.8)",
                                    }}
                                  >
                                    ���
                                  </span>
                                )}
                              </div>
                              <p className="text-[11px] text-muted-foreground mt-0.5 line-clamp-2">
                                {app.description}
                              </p>
                            </div>
                            <div className="mt-auto flex gap-1.5">
                              {isInstalled ? (
                                <button
                                  type="button"
                                  onClick={() => handleLaunch(app)}
                                  data-ocid={`appstore.featured.secondary_button.${i + 1}`}
                                  className="flex-1 flex items-center justify-center gap-1 h-7 rounded-lg text-xs transition-all"
                                  style={{
                                    background: "rgba(39,215,224,0.1)",
                                    border: "1px solid rgba(39,215,224,0.3)",
                                    color: "rgba(39,215,224,0.9)",
                                  }}
                                >
                                  <ExternalLink className="w-3 h-3" />
                                  Launch
                                </button>
                              ) : (
                                <button
                                  type="button"
                                  onClick={() => setConfirmApp(app)}
                                  data-ocid={`appstore.featured.primary_button.${i + 1}`}
                                  className="flex-1 flex items-center justify-center gap-1 h-7 rounded-lg text-xs transition-all"
                                  style={{
                                    background: "rgba(39,215,224,0.12)",
                                    border: "1px solid rgba(39,215,224,0.35)",
                                    color: "rgba(39,215,224,1)",
                                  }}
                                >
                                  <Download className="w-3 h-3" />
                                  Install
                                </button>
                              )}
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                )}

              {/* All apps grid */}
              <div>
                {(selectedCategory !== "All" || debouncedQuery) && (
                  <div className="flex items-center gap-2 mb-3">
                    <span>{CATEGORY_ICONS[selectedCategory]}</span>
                    <h3 className="text-xs font-semibold text-foreground/70">
                      {debouncedQuery
                        ? `Results for "${debouncedQuery}"`
                        : selectedCategory}
                    </h3>
                  </div>
                )}
                {filteredApps.length === 0 ? (
                  <div
                    className="flex flex-col items-center justify-center h-32 gap-2 text-muted-foreground/40"
                    data-ocid="appstore.empty_state"
                  >
                    <Package className="w-10 h-10" />
                    <p className="text-xs">No apps found</p>
                  </div>
                ) : (
                  <div className="grid grid-cols-1 gap-2">
                    {filteredApps.slice(0, visibleCount).map((app, i) => {
                      const isCore =
                        app.isCore || CORE_APP_IDS.has(app.appId ?? "");
                      const isInstalled = isCore || installedIds.has(app.id);
                      return (
                        <div
                          key={app.id}
                          data-ocid={`appstore.item.${i + 1}`}
                          className="rounded-lg p-3 transition-colors flex items-center gap-3"
                          style={{
                            background: "rgba(18,32,38,0.6)",
                            border: isInstalled
                              ? "1px solid rgba(39,215,224,0.15)"
                              : "1px solid rgba(42,58,66,0.6)",
                            contentVisibility: "auto",
                            containIntrinsicSize: "0 80px",
                          }}
                        >
                          {/* App icon */}
                          <div
                            className="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
                            style={{
                              background: "rgba(39,215,224,0.08)",
                            }}
                          >
                            {app.appId ? (
                              <AppIcon appId={app.appId} size={20} />
                            ) : (
                              <AppIcon appId="unknown" size={20} />
                            )}
                          </div>

                          {/* Info */}
                          <div className="flex-1 min-w-0">
                            <div className="flex items-center gap-2 flex-wrap">
                              <span className="text-sm font-semibold text-foreground">
                                {app.name}
                              </span>
                              {app.version && (
                                <span className="text-[10px] font-mono text-muted-foreground/40">
                                  v{app.version}
                                </span>
                              )}
                              {isCore ? (
                                <span
                                  className="flex items-center gap-0.5 text-[10px] px-1.5 py-0.5 rounded-full"
                                  style={{
                                    background: "rgba(100,116,139,0.15)",
                                    border: "1px solid rgba(100,116,139,0.3)",
                                    color: "rgba(148,163,184,0.9)",
                                  }}
                                >
                                  <Lock className="w-2 h-2" />
                                  Core App
                                </span>
                              ) : isInstalled ? (
                                <span
                                  className="text-[10px] px-1.5 py-0.5 rounded-full"
                                  style={{
                                    background: "rgba(39,215,224,0.1)",
                                    border: "1px solid rgba(39,215,224,0.3)",
                                    color: "rgba(39,215,224,0.8)",
                                  }}
                                >
                                  ��� On Desktop
                                </span>
                              ) : null}
                              {app.category && (
                                <span
                                  className="text-[10px] px-1.5 py-0.5 rounded text-muted-foreground/50"
                                  style={{
                                    background: "var(--os-border-subtle)",
                                  }}
                                >
                                  {app.category}
                                </span>
                              )}
                            </div>
                            <p className="text-xs text-muted-foreground mt-0.5 truncate">
                              {app.description}
                            </p>
                            <div className="flex flex-wrap gap-1 mt-1.5">
                              {(app.permissions ?? []).map((perm) => (
                                <span
                                  key={perm}
                                  className="flex items-center gap-0.5 text-[10px] px-1.5 py-0.5 rounded"
                                  style={{
                                    background: "rgba(255,200,0,0.06)",
                                    border: "1px solid rgba(255,200,0,0.15)",
                                    color: "rgba(255,200,0,0.7)",
                                  }}
                                >
                                  <Shield className="w-2 h-2" />
                                  {perm}
                                </span>
                              ))}
                            </div>
                          </div>

                          {/* Actions */}
                          <div className="flex items-center gap-1 flex-shrink-0">
                            {isCore ? (
                              <button
                                type="button"
                                onClick={() => handleLaunch(app)}
                                data-ocid={`appstore.secondary_button.${i + 1}`}
                                className="flex items-center gap-1 px-2 h-7 rounded text-xs transition-all"
                                style={{
                                  background: "rgba(100,116,139,0.1)",
                                  border: "1px solid rgba(100,116,139,0.25)",
                                  color: "rgba(148,163,184,0.8)",
                                }}
                              >
                                <ExternalLink className="w-3 h-3" />
                                Open
                              </button>
                            ) : isInstalled ? (
                              <>
                                {app.appId && (
                                  <button
                                    type="button"
                                    onClick={() => handleLaunch(app)}
                                    data-ocid={`appstore.secondary_button.${i + 1}`}
                                    className="flex items-center gap-1 px-2 h-7 rounded text-xs transition-all"
                                    style={{
                                      background: "rgba(39,215,224,0.08)",
                                      border: "1px solid rgba(39,215,224,0.25)",
                                      color: "rgba(39,215,224,0.85)",
                                    }}
                                  >
                                    <ExternalLink className="w-3 h-3" />
                                    Launch
                                  </button>
                                )}
                                <button
                                  type="button"
                                  onClick={() => handleUninstall(app)}
                                  data-ocid={`appstore.delete_button.${i + 1}`}
                                  className="flex items-center gap-1 px-2 h-7 rounded text-xs text-destructive/70 hover:text-destructive hover:bg-destructive/10 transition-colors"
                                >
                                  <Trash2 className="w-3 h-3" />
                                </button>
                              </>
                            ) : (
                              <button
                                type="button"
                                onClick={() => setConfirmApp(app)}
                                data-ocid={`appstore.install.button.${i + 1}`}
                                className="flex items-center gap-1 px-2 h-7 rounded text-xs transition-all"
                                style={{
                                  background: "rgba(39,215,224,0.1)",
                                  border: "1px solid rgba(39,215,224,0.3)",
                                  color: "rgba(39,215,224,0.9)",
                                }}
                              >
                                <Download className="w-3 h-3" />
                                Install
                              </button>
                            )}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                )}
                {filteredApps.length > visibleCount && (
                  <div ref={sentinelRef} className="h-8" />
                )}
              </div>
            </div>
          )}
        </div>
      </div>

      {/* Confirm dialog */}
      {confirmApp && (
        <div
          className="absolute inset-0 flex items-center justify-center z-50"
          style={{ background: "rgba(0,0,0,0.7)", backdropFilter: "blur(4px)" }}
          data-ocid="appstore.dialog"
        >
          <div className="os-window p-5 max-w-xs w-full mx-4">
            <div className="flex items-center gap-3 mb-3">
              <div
                className="w-10 h-10 rounded-xl flex items-center justify-center"
                style={{
                  background: "rgba(39,215,224,0.08)",
                }}
              >
                {confirmApp.appId ? (
                  <AppIcon appId={confirmApp.appId} size={20} />
                ) : (
                  <AppIcon appId="unknown" size={20} />
                )}
              </div>
              <div>
                <h3 className="text-sm font-semibold text-foreground">
                  Install {confirmApp.name}?
                </h3>
                <p className="text-[10px] font-mono text-muted-foreground/50">
                  v{confirmApp.version}
                </p>
              </div>
            </div>
            <p className="text-xs text-muted-foreground mb-3">
              {confirmApp.description}
            </p>
            {(confirmApp.permissions ?? []).length > 0 && (
              <div className="mb-4">
                <p className="text-xs font-medium text-muted-foreground mb-1.5">
                  Requires permissions:
                </p>
                <div className="flex flex-wrap gap-1">
                  {(confirmApp.permissions ?? []).map((perm) => (
                    <span
                      key={perm}
                      className="flex items-center gap-0.5 text-[10px] px-1.5 py-0.5 rounded"
                      style={{
                        background: "rgba(255,200,0,0.08)",
                        border: "1px solid rgba(255,200,0,0.2)",
                        color: "rgba(255,200,0,0.8)",
                      }}
                    >
                      <Shield className="w-2 h-2" />
                      {perm}
                    </span>
                  ))}
                </div>
              </div>
            )}
            <div className="flex gap-2">
              <button
                type="button"
                onClick={() => handleInstall(confirmApp)}
                data-ocid="appstore.confirm_button"
                className="flex-1 h-8 rounded text-xs font-semibold transition-all"
                style={{
                  background: "rgba(39,215,224,0.15)",
                  border: "1px solid rgba(39,215,224,0.4)",
                  color: "rgba(39,215,224,1)",
                }}
              >
                Install &amp; Launch
              </button>
              <button
                type="button"
                onClick={() => setConfirmApp(null)}
                data-ocid="appstore.cancel_button"
                className="flex-1 h-8 rounded text-xs text-muted-foreground hover:text-foreground hover:bg-white/5 transition-colors"
              >
                Cancel
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
