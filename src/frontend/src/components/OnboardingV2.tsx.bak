      LucideIcon: FileText,
    },
    {
      id: 69,
      appId: "kanban",
      name: "Kanban Board",
      description: "Drag-and-drop project board",
      color: "#27D7E0",
      emoji: "🗂️",
      emojiColor: "#27D7E0",
      LucideIcon: Columns,
    },
    {
      id: 90,
      appId: "apitester",
      name: "API Tester",
      description: "Test HTTP endpoints visually",
      color: "#6366F1",
      emoji: "🧪",
      emojiColor: "#6366F1",
      LucideIcon: Globe,
    },
  ],
  poweruser: [
    {
      id: 5,
      appId: "processmonitor",
      name: "Process Monitor",
      description: "Live cycles and process stats",
      color: "#06B6D4",
      emoji: "📊",
      emojiColor: "#06B6D4",
      LucideIcon: Activity,
    },
    {
      id: 7,
      appId: "texteditor",
      name: "Text Editor",
      description: "Lightweight editor with syntax modes",
      color: "#F97316",
      emoji: "📝",
      emojiColor: "#F97316",
      LucideIcon: FileText,
    },
    {
      id: 69,
      appId: "kanban",
      name: "Kanban Board",
      description: "Drag-and-drop project board",
      color: "#27D7E0",
      emoji: "🗂️",
